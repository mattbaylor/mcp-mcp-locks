  "description": "MCP server wrapping the mcp-locks CLI — exposes claim/release/list/who/reap/doctor as native MCP tools for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-mcp-locks": "dist/index.js"
  },
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "watch": "./node_modules/.bin/tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-locks",
    "coordination",
    "playwright",
    "ai",
    "dev-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
